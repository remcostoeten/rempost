<section class="space-y-6">
  <h1 class="text-3xl font-semibold tracking-tight">Operational Dashboard</h1>
  <div class="grid grid-cols-2 gap-4">
    <div class="rounded-xl bg-zinc-100 p-4"><p class="text-sm text-zinc-500">Active Shipments</p><p class="text-2xl"><%= length(@shipments) %></p></div>
    <div class="rounded-xl bg-zinc-100 p-4"><p class="text-sm text-zinc-500">Recent Emails</p><p class="text-2xl"><%= length(@emails) %></p></div>
  </div>
</section>

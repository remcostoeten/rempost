<section class="min-h-screen bg-zinc-50 px-6 py-10 text-zinc-950">
  <div class="mx-auto max-w-7xl space-y-6">
    <header class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-sm font-semibold text-zinc-950">
        <div class="grid h-7 w-7 place-items-center rounded-md bg-zinc-950 text-white shadow-sm">
          <.icon name="hero-envelope" class="h-3.5 w-3.5" />
        </div>
        Postbus
      </div>

      <div class="text-xs font-medium text-zinc-500">
        Admin
      </div>
    </header>

    <div class="rounded-2xl border border-zinc-200 bg-white/90 p-5 shadow-sm backdrop-blur">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
            Dashboard
          </p>

          <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-950">
            Inbound emails
          </h1>

          <p class="mt-1 text-sm leading-6 text-zinc-500">
            Ingestion log for the parser. Live-updates as Cloudflare delivers mail.
          </p>
        </div>

        <form phx-change="search" class="w-full md:w-96">
          <div class="flex items-center gap-3 rounded-xl border border-zinc-200 bg-white px-4 py-3 shadow-sm transition-colors focus-within:border-amber-500">
            <.icon name="hero-magnifying-glass" class="h-4 w-4 shrink-0 text-zinc-400" />

            <input
              type="text"
              name="q"
              value={@search}
              phx-debounce="300"
              placeholder="Search sender, subject, message ID, status"
              class="min-w-0 flex-1 bg-transparent text-sm text-zinc-950 outline-none placeholder:text-zinc-400"
            />
          </div>
        </form>
      </div>

      <div class="mt-4 text-xs text-zinc-500">
        Showing
        <span class="font-medium text-zinc-950"><%= @total_count %></span>
        email<%= if @total_count == 1, do: "", else: "s" %>

        <%= if @search != "" do %>
          for query
          <span class="font-medium text-zinc-950">"<%= @search %>"</span>
        <% end %>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-zinc-200 bg-zinc-50/70 px-4 py-3">
        <div class="flex items-center gap-2 text-sm">
          <.icon name="hero-inbox" class="h-4 w-4 text-zinc-500" />
          <span class="font-semibold text-zinc-950">Inbox</span>
          <span class="rounded-full bg-amber-500/15 px-2 py-0.5 text-xs font-semibold text-amber-700">
            <%= @total_count %>
          </span>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-zinc-50 text-xs uppercase tracking-wider text-zinc-500">
            <tr>
              <th class="px-4 py-3 text-left font-semibold">Received</th>
              <th class="px-4 py-3 text-left font-semibold">From</th>
              <th class="px-4 py-3 text-left font-semibold">Subject</th>
              <th class="px-4 py-3 text-left font-semibold">Status</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-zinc-100">
            <%= if @emails == [] do %>
              <tr>
                <td class="px-4 py-10 text-center text-zinc-500" colspan="4">
                  No emails yet. Post to
                  <code class="rounded-md bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-700">
                    /api/inbound/email
                  </code>
                  to ingest.
                </td>
              </tr>
            <% end %>

            <%= for email <- @emails do %>
              <tr class="align-top transition hover:bg-zinc-50/80">
                <td class="whitespace-nowrap px-4 py-3 text-zinc-500">
                  <%= Calendar.strftime(email.received_at, "%Y-%m-%d %H:%M") %>
                </td>

                <td class="px-4 py-3 text-zinc-700">
                  <%= email.from_email %>
                </td>

                <td class="px-4 py-3">
                  <.link
                    navigate={~p"/emails/#{email.id}"}
                    class="font-medium text-zinc-950 underline-offset-4 hover:text-amber-700 hover:underline"
                  >
                    <%= email.subject || "(no subject)" %>
                  </.link>
                </td>

                <td class="px-4 py-3">
                  <span class={[
                    "inline-flex rounded-md border px-2 py-1 text-xs font-semibold",
                    email.status == :failed && "border-red-200 bg-red-50 text-red-700",
                    email.status == :processing && "border-amber-200 bg-amber-50 text-amber-700",
                    email.status == :parsed && "border-emerald-200 bg-emerald-50 text-emerald-700",
                    email.status == :pending && "border-zinc-200 bg-zinc-50 text-zinc-700"
                  ]}>
                    <%= email.status %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>